# MTProto Uploader — Environment Variables
# =========================================
# Copy this file to .env and fill in your values.
# Load it with: python-dotenv or export manually.

# ── REQUIRED: Telegram API credentials ────────────────────────────────────
# Get from https://my.telegram.org → API development tools
API_ID=12345678
API_HASH=your_api_hash_here

# ── AUTH (choose ONE of the following) ────────────────────────────────────

# Option A: Session string (RECOMMENDED for production/servers)
# Generate with: python mtproto_uploader/generate_session.py
SESSION_STRING=

# Option B: Phone number for interactive user login (first run only)
# After first login, SESSION_STRING is auto-saved to the session file
PHONE_NUMBER=+1234567890

# Option C: Bot token login (note: bots are limited to ~50MB via MTProto)
# For large files, use a user account (Option A or B) instead.
# BOT_TOKEN=123456:ABC-DEF...

# ── YOUR BOT TOKEN (for sending messages and live progress editing) ─────────
# This is your bot's token from @BotFather. Separate from the MTProto auth above.
BOT_TOKEN=123456:ABC-DEF...

# ── Download settings ──────────────────────────────────────────────────────
DOWNLOAD_DIR=/tmp/mtproto_downloads
MAX_FILESIZE_MB=2000

# Optional: Path to cookies.txt for age-restricted YouTube videos
# Export from your browser with the "Get cookies.txt LOCALLY" extension
# COOKIES_FILE=/path/to/cookies.txt

# ── API Server settings (if using the REST API) ────────────────────────────
HOST=0.0.0.0
PORT=8080
